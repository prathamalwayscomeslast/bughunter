# Copy this to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is in .gitignore.

aws_region        = "us-east-1"
environment       = "dev"
instance_type     = "t3.micro"
ssh_allowed_cidr  = ""
ssh_public_key    = ""

# Secrets — these are passed as TF_VAR_* env vars in CI, not stored here.
# redis_url              = ""
# database_url           = ""
# webhook_secret         = ""
# github_app_id          = ""
# github_private_key_b64 = ""
